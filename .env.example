# kobra-full-stack-ai-2
# Copy this file to .env and adjust values as needed.

# ----------------------------
# General
# ----------------------------
NODE_ENV=development

# ----------------------------
# market-service (Node.js)
# ----------------------------
MARKET_GATEWAY_PORT=3001
MARKET_GATEWAY_BASE_URL=http://localhost:3001

# Where the agent service is reachable from within Docker network.
# (Compose typically sets this up; keep consistent with compose service name.)
AGENT_PYTHON_BASE_URL=http://agent:8000

# CORS
CORS_ORIGIN=http://localhost:3000

# Example API key (optional)
MARKET_GATEWAY_API_KEY=changeme

# ----------------------------
# agent (Python)
# ----------------------------
AGENT_PYTHON_PORT=8000

# OpenAI / LLM configuration (optional; example only)
OPENAI_API_KEY=changeme
OPENAI_MODEL=gpt-4o-mini

# Realtime voice (speech-to-speech over WebRTC). OPENAI_API_KEY is required.
REALTIME_MODEL=gpt-realtime-mini
REALTIME_VOICE=marin
REALTIME_TRANSCRIBE_MODEL=whisper-1

# Optional: set to true to enable verbose logging
AGENT_LOG_LEVEL=info

# ----------------------------
# dashboard (React)
# ----------------------------
DASHBOARD_PORT=3000
# CRA/React dev server typically reads REACT_APP_* at build time
REACT_APP_API_BASE_URL=http://localhost:3001

# ----------------------------
# Optional shared / demo data
# ----------------------------
# Example: where to expose mock data or credentials to the agent
DEMO_MARKET_TICKER=AAPL
DEMO_MARKET_SOURCE=yfinance